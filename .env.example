# --- MongoDB (Atlas free M0 cluster, or local) ---
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/fitsphere?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/fitsphere

# --- Auth (two separate secrets; long random strings) ---
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# --- Frontend origin (CORS) ---
CLIENT_ORIGIN=http://localhost:5173

# --- Server ---
PORT=4001

# --- Realtime (Socket.IO) ---
SOCKET_ENABLED=true
SOCKET_PORT=9093
